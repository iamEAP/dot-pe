{
  "name": "gatsby-london",
  "private": true,
  "description": "A custom, image-centric theme for Gatsby",
  "version": "1.0.0",
  "author": "Imed Adel <aadelimed@gmail.com>",
  "bugs": {
    "url": "https://github.com/ImedAdel/gatsby-london/issues"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "dayjs": "^1.11.21",
    "gatsby": "^5.15.0",
    "gatsby-link": "^5.3.1",
    "gatsby-plugin-client-side-redirect": "^1.1.0",
    "gatsby-plugin-feed": "^5.3.1",
    "gatsby-plugin-google-gtag": "^5.11.0",
    "gatsby-plugin-i18n": "^1.0.1",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-manifest": "^5.3.1",
    "gatsby-plugin-netlify": "^5.1.0",
    "gatsby-plugin-offline": "^6.11.0",
    "gatsby-plugin-postcss": "^6.11.0",
    "gatsby-plugin-purgecss": "^6.2.1",
    "gatsby-plugin-sharp": "^5.8.1",
    "gatsby-plugin-sitemap": "^6.16.0",
    "gatsby-react-router-scroll": "^6.3.0",
    "gatsby-remark-copy-linked-files": "^6.11.0",
    "gatsby-remark-images": "^7.3.1",
    "gatsby-remark-prismjs": "^7.11.0",
    "gatsby-remark-responsive-iframe": "^6.11.0",
    "gatsby-remark-smartypants": "^6.11.0",
    "gatsby-script": "^2.3.0",
    "gatsby-source-filesystem": "^5.3.1",
    "gatsby-transformer-remark": "^6.3.2",
    "gatsby-transformer-sharp": "^5.3.1",
    "i18next": "^19.8.4",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^11.8.5",
    "url-join": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "@types/react": "^18.2.13",
    "@types/react-dom": "^18.2.6",
    "autoprefixer": "^10.4.19",
    "baseline-browser-mapping": "^2.10.37",
    "cheerio": "^1.2.0",
    "gh-pages": "^5.0.0",
    "husky": "^9.1.7",
    "postcss-custom-properties": "^13.3.12",
    "postcss-easy-import": "^4.0.0",
    "prettier": "^3.0.0",
    "pretty-quick": "^4.0.0",
    "typescript": "^5.1.3"
  },
  "homepage": "https://github.com/gatsbyjs/gatsby-starter-blog#readme",
  "keywords": [
    "gatsby",
    "ghost",
    "gallery",
    "blog",
    "starter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImedAdel/gatsby-london.git"
  },
  "scripts": {
    "build": "gatsby build",
    "deploy": "gatsby clean && gatsby build --prefix-paths && gh-pages -d public -b master && gh-pages -d public -b pages -o codeberg",
    "develop": "gatsby develop",
    "format": "prettier --write \"{src,tests}/**/*.{js,jsx,ts,tsx}\" \"*.{js,ts,tsx}\"",
    "prepare": "husky",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\"",
    "typecheck": "tsc --noEmit",
    "verify:build": "gatsby clean && gatsby build --prefix-paths",
    "verify": "npm run typecheck && npm run verify:build && npm run verify:fast",
    "verify:fast": "node --test tests/build/*.test.ts"
  },
  "browserslist": [
    "last 2 versions"
  ]
}
